APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=9900
DATABASE_URL=sqlite:///data/dataops_oncall.db
LOG_LEVEL=INFO

# Default providers keep the MVP fully local and deterministic.
LLM_PROVIDER=local
EMBEDDING_PROVIDER=local

# DeepSeek OpenAI-compatible chat completion.
# Set LLM_PROVIDER=deepseek to append a model-generated summary to reports.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=30

# Alibaba Cloud Model Studio / DashScope OpenAI-compatible embeddings.
# Set EMBEDDING_PROVIDER=aliyun and rebuild the RAG index to store embeddings.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSIONS=1024
DASHSCOPE_TIMEOUT_SECONDS=30
RAG_EMBEDDING_WEIGHT=4.0
